# Nginx Configuration Example for Go Audio Streamer
# Location: /etc/nginx/sites-available/streamer

server {
    listen 80;
    listen [::]:80;
    server_name yourdomain.com; # Replace with your domain

    # Optional: Redirect HTTP to HTTPS
    # return 301 https://$server_name$request_uri;

    # Shortcut for station master playlists
    # Example: http://yourdomain.com/radio1/ -> /hls/radio1/master.m3u8
    location ~ ^/([a-zA-Z0-9_-]+)/$ {
        return 302 /hls/$1/master.m3u8;
    }

    # Proxy HLS and API to Go Streamer
    location / {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
        
        # CORS Headers (already handled by Go Streamer, but can be reinforced here)
        add_header 'Access-Control-Allow-Origin' '*' always;
    }

    # Optimization for HLS segments
    location /hls/ {
        proxy_pass http://127.0.0.1:8080/hls/;
        expires 1s;
        add_header Cache-Control "public, must-revalidate, proxy-revalidate";
    }
}

# Example for HTTPS (SSL)
